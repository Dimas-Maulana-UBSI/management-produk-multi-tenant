{
  "openapi": "3.0.3",
  "info": {
    "title": "Produk RESTful API",
    "description": "API Spec for Produk RESTful API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/produk": {
      "get": {
        "security": [{ "ProdukAuth": [] }],
        "tags": ["Produk"],
        "description": "List Produk with pagination",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 }},
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 }}
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponsePagination" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponse" } } } }
        }
      },
      "post": {
        "security": [{ "ProdukAuth": [] }],
        "tags": ["Produk"],
        "description": "Create a new Produk",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProdukRequest" } } } },
        "responses": {
          "200": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponseSingleProduk" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponse" } } } }
        }
      }
    },
    "/produk/{id}": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
      "get": {
        "security": [{ "ProdukAuth": [] }],
        "tags": ["Produk"],
        "description": "Get produk by id",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponseSingleProduk" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponse" } } } }
        }
      },
      "put": {
        "security": [{ "ProdukAuth": [] }],
        "tags": ["Produk"],
        "description": "Update produk",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProdukRequest" } } } },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponseSingleProduk" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponse" } } } }
        }
      },
      "delete": {
        "security": [{ "ProdukAuth": [] }],
        "tags": ["Produk"],
        "description": "Delete produk",
        "responses": {
          "200": { "description": "Deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponse" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ProdukAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key for tenant scoping"
      }
    },
    "schemas": {
      "WebResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "message": { "type": "string" },
          "data": { "type": "object" }
        }
      },
      "Produk": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "nama": { "type": "string" },
          "harga": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ProdukRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "harga": { "type": "integer" }
        },
        "required": ["name", "harga"]
      },
      "ProdukPaginationResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Produk" } },
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "totalData": { "type": "integer" },
          "totalPage": { "type": "integer" }
        }
      },
      "WebResponsePagination": {
        "allOf": [ { "$ref": "#/components/schemas/WebResponse" }, { "properties": { "data": { "$ref": "#/components/schemas/ProdukPaginationResponse" } } } ]
      },
      "WebResponseSingleProduk": {
        "allOf": [ { "$ref": "#/components/schemas/WebResponse" }, { "properties": { "data": { "$ref": "#/components/schemas/Produk" } } } ]
      },
      "WebResponseLogin": {
        "allOf": [ { "$ref": "#/components/schemas/WebResponse" }, { "properties": { "data": { "type": "object", "properties": { "name": { "type": "string" }, "api_key": { "type": "string" } } } } } ]
      },
      "WebResponseRegistrasi": {
        "allOf": [ { "$ref": "#/components/schemas/WebResponse" }, { "properties": { "data": { "type": "object", "properties": { "name": { "type": "string" }, "api_key": { "type": "string" }, "db_name": { "type": "string" } } } } } ]
      },
      "WebResponseTenant": {
        "allOf": [ { "$ref": "#/components/schemas/WebResponse" }, { "properties": { "data": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "api_key": { "type": "string" }, "db_name": { "type": "string" }, "status": { "type": "string" } } } } } ]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["name", "password"]
      },
      "RegistrasiRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["name", "password"]
      }
    }
  }
}
